# Single .env shared by all four tasks.
# Copy this to `.env` (same directory) and fill in real values.

# --- Postgres (Supabase) ---------------------------------------------------
# Use the transaction-mode POOLER URL (port 6543), not direct Postgres
# (5432) — direct is blocked by most consumer ISPs.
# Supabase dashboard → Project Settings → Database → Connection string → URI
# If your password contains special characters (e.g. '#'), percent-encode them (# → %23).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Embeddings (Task 1B + Task 2) ----------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- LLM (Task 2 + Task 4) ------------------------------------------------
# We use Groq's free tier because Claude/OpenAI credits were unavailable at
# build time. Get a key at https://console.groq.com → API Keys.
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
